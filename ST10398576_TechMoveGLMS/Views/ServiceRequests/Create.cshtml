@model ST10398576_TechMoveGLMS.Models.ServiceRequest
@{
    ViewData["Title"] = "Create Service Request";
}

<h2>Create Service Request</h2>

<form asp-action="Create" method="post">
    <div class="form-group">
        <label>Contract ID</label>
        <select asp-for="ContractId" class="form-control" asp-items="ViewBag.Contracts"></select>
    </div>
    
    <div class="form-group">
        <label>Description</label>
        <input asp-for="ServiceDescription" class="form-control" />
    </div>

    <div class="form-group">
        <label>Cost</label>
        <input asp-for="ServiceCost" type="number" step="0.01" class="form-control" />
    </div>

    <div class="form-group">
        <label>Status</label>
        <select asp-for="ServiceStatus" class="form-control">
            <option value="Pending">Pending</option>
            <option value="Completed">Completed</option>
        </select>
    </div>

    <button type="submit" class="btn btn-success">Create</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
