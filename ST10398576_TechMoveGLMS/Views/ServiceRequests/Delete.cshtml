@model ST10398576_TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Delete Service Request";
}

<h2>Delete Service Request</h2>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>ServiceRequest</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ContractId</dt>
        <dd class="col-sm-10">@Model.ContractId</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.ServiceDescription</dd>

        <dt class="col-sm-2">Cost (ZAR)</dt>
        <dd class="col-sm-10">@Model.ServiceCost</dd>

        <dt class="col-sm-2">Status</dt>
        <dd class="col-sm-10">@Model.ServiceStatus</dd>
    </dl>
</div>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="ServiceRequestId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
