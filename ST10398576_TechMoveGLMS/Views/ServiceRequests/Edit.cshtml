@model ST10398576_TechMoveGLMS.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit Service Request";
}

<h2>Edit Service Request</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ServiceRequestId" />

    <div class="form-group">
        <label asp-for="ContractId" class="control-label"></label>
        <input asp-for="ContractId" class="form-control" />
        <span asp-validation-for="ContractId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ServiceDescription" class="control-label"></label>
        <input asp-for="ServiceDescription" class="form-control" />
        <span asp-validation-for="ServiceDescription" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ServiceCost" class="control-label"></label>
        <input asp-for="ServiceCost" class="form-control" />
        <span asp-validation-for="ServiceCost" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ServiceStatus" class="control-label"></label>
        <input asp-for="ServiceStatus" class="form-control" />
        <span asp-validation-for="ServiceStatus" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
