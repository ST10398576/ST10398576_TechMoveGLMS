<table class="table table-striped">
    <thead>
        <tr>
            <th>ContractId</th>
            <th>Description</th>
            <th>Cost (ZAR)</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ContractId</td>
                <td>@item.ServiceDescription</td>
                <td>R @item.ServiceCost</td>
                <td>@item.ServiceStatus</td>
                <td>
                    <a asp-action="Edit" asp-route-servicerequestid="@item.ServiceRequestId">Edit</a> |
                    <a asp-action="Details" asp-route-servicerequestid="@item.ServiceRequestId">Details</a> |
                    <a asp-action="Delete" asp-route-servicerequestid="@item.ServiceRequestId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
