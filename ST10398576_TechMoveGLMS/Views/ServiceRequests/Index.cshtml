@model IEnumerable<ST10398576_TechMoveGLMS.Models.ServiceRequest>
@{
    ViewData["Title"] = "Service Requests";
    var selectedStartDate = Context.Request.Query["startDate"].ToString();
    var selectedEndDate = Context.Request.Query["endDate"].ToString();
}

<h2>Service Requests</h2>

<!-- Filter Form -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-4">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value="">All</option>
                <option value="Pending">Pending</option>
                <option value="Completed">Completed</option>
            </select>
        </div>
        <div class="col-md-4">
            <label>Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@selectedStartDate" />
        </div>
        <div class="col-md-4">
            <label>End Date</label>
            <input type="date" name="endDate" class="form-control" value="@selectedEndDate" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-2">Filter</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Clear Filters</a>
</form>

<!-- Results Table -->
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Request ID</th>
            <th>Description</th>
            <th>Cost</th>
            <th>Status</th>
            <th>Contract ID</th>
            <th>Client Name</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var request in Model)
    {
        <tr>
            <td>@request.ServiceRequestId</td>
            <td>@request.ServiceDescription</td>
            <td>R @request.ServiceCost</td>
            <td>@request.ServiceStatus</td>
            <td>@request.ContractId</td>
            <td>@request.Contract?.Client?.ClientName</td>
            <td>
                <a asp-action="Details" asp-route-id="@request.ServiceRequestId" class="btn btn-info btn-sm">Details</a>
                <a asp-action="Edit" asp-route-id="@request.ServiceRequestId" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@request.ServiceRequestId" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success">Create New Request</a>
