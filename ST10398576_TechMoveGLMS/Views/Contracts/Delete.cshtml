@model ST10398576_TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Delete Contract";
}

<h2>Delete Contract</h2>

<h3>Are you sure you want to delete this contract?</h3>

<dl class="row">
    <dt class="col-sm-2">ClientId</dt>
    <dd class="col-sm-10">@Model.ClientId</dd>

    <dt class="col-sm-2">Status</dt>
    <dd class="col-sm-10">@Model.ContractStatus</dd>

    <dt class="col-sm-2">ServiceLevel</dt>
    <dd class="col-sm-10">@Model.ContractServiceLevel</dd>
</dl>

<form asp-action="DeleteConfirmed" method="post">
    <input type="hidden" asp-for="ContractId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
