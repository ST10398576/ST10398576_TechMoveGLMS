@model ST10398576_TechMoveGLMS.Models.Contract

@{
    ViewData["Title"] = "Edit Contract";
}

<h2>Edit Contract</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post" enctype="multipart/form-data">
    <input type="hidden" asp-for="ContractId" />

    <div class="form-group">
        <label asp-for="ClientId" class="control-label"> Client Name </label>
        <select asp-for="ClientId" class="form-control" asp-items="ViewBag.ClientId"></select>
        <span asp-validation-for="ClientId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="StartDate" class="control-label"> Start Date </label>
        <input asp-for="StartDate" type="date" class="form-control" />
        <span asp-validation-for="StartDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="EndDate" class="control-label"> EndDate </label>
        <input asp-for="EndDate" type="date" class="form-control" />
        <span asp-validation-for="EndDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ContractStatus" class="control-label"> Status </label>
        <select asp-for="ContractStatus" class="form-control" asp-items="ViewBag.StatusList"></select>
        <span asp-validation-for="ContractStatus" class="text-danger"></span>

    <div class="form-group">
        <label asp-for="ContractServiceLevel" class="control-label"> Service Level </label>
        <select asp-for="ContractServiceLevel" class="form-control" asp-items="ViewBag.ServiceLevelList"></select>
        <span asp-validation-for="ContractServiceLevel" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label>Replace Agreement (PDF)</label>
        <input type="file" name="file" class="form-control" />
        <small class="form-text text-muted">
            Leave blank to keep the existing file.
        </small>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
