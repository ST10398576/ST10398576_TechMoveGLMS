@model IEnumerable<ST10398576_TechMoveGLMS.Models.Contract>

@{
    ViewData["Title"] = "Contracts";
}

<h2>Contracts</h2>

<p>
    <a asp-action="Create" class="btn btn-success">Create New</a>
</p>

<!-- Search/Filter Form -->
<form method="get" class="mb-3">
    <label>Contract Status</label>
    <select name="status" class="form-control mb-2">
        <option value=""> --All Status-- </option>
        <option value="Draft" selected="@(ViewData["status"]?.ToString() == "Draft")">Draft</option>
        <option value="On Hold" selected="@(ViewData["status"]?.ToString() == "On Hold")">On Hold</option>
        <option value="Active" selected="@(ViewData["status"]?.ToString() == "Active")">Active</option>
        <option value="Expired" selected="@(ViewData["status"]?.ToString() == "Expired")">Expired</option>
    </select>

    <label>Contract Service Level</label>
    <select name="serviceLevel" class="form-control mb-2">
        <option value=""> --All Levels-- </option>
        <option value="High" selected="@(ViewData["serviceLevel"]?.ToString() == "High")">High</option>
        <option value="Medium" selected="@(ViewData["serviceLevel"]?.ToString() == "Medium")">Medium</option>
        <option value="Low" selected="@(ViewData["serviceLevel"]?.ToString() == "Low")">Low</option>
    </select>

    <label>Date Range</label>
    <input type="date" name="startDate" value="@ViewData["startDate"]" class="form-control mb-2" />
    <input type="date" name="endDate" value="@ViewData["endDate"]" class="form-control mb-2" />

    <button type="submit" class="btn btn-primary">Filter</button>
</form>



<table class="table table-striped">
    <thead>
        <tr>
            <th>Contract ID</th>
            <th>Client Name </th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Service Level</th>
            <th>Agreement PDF</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.ContractId</td>
                <td>@item.Client.ClientName</td>
                <td>@item.StartDate.ToShortDateString()</td>
                <td>@item.EndDate.ToShortDateString()</td>
                <td>@item.ContractStatus</td>
                <td>@item.ContractServiceLevel</td>
                <td>
                    @if (!string.IsNullOrEmpty(item.PdfFilePath))
                    {
                        <a href="@Url.Content(item.PdfFilePath)" target="_blank">View PDF</a>
                    }
                </td>

                <td>
                    <a asp-action="Edit" asp-route-contractid="@item.ContractId">Edit</a> |
                    <a asp-action="Details" asp-route-contractid="@item.ContractId">Details</a> |
                    <a asp-action="Delete" asp-route-contractid="@item.ContractId">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
