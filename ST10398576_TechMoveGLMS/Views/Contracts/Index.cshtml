@model IEnumerable<ST10398576_TechMoveGLMS.Models.Contract>
@{
    ViewData["Title"] = "Contracts";
    var selectedStartDate = Context.Request.Query["startDate"].ToString();
    var selectedEndDate = Context.Request.Query["endDate"].ToString();
}

<h2>Contracts</h2>

<!-- Filter Form -->
<form asp-action="Index" method="get" class="mb-3">
    <div class="row">
        <div class="col-md-3">
            <label>Status</label>
            <select name="status" class="form-control">
                <option value=""> --All Status-- </option>
                <option value="Draft" selected="@(ViewData["status"]?.ToString() == "Draft")">Draft</option>
                <option value="On Hold" selected="@(ViewData["status"]?.ToString() == "On Hold")">On Hold</option>
                <option value="Active" selected="@(ViewData["status"]?.ToString() == "Active")">Active</option>
                <option value="Expired" selected="@(ViewData["status"]?.ToString() == "Expired")">Expired</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Service Level</label>
            <select name="serviceLevel" class="form-control">
                <option value=""> --All Levels-- </option>
                <option value="High" selected="@(ViewData["serviceLevel"]?.ToString() == "High")">High</option>
                <option value="Medium" selected="@(ViewData["serviceLevel"]?.ToString() == "Medium")">Medium</option>
                <option value="Low" selected="@(ViewData["serviceLevel"]?.ToString() == "Low")">Low</option>
            </select>
        </div>
        <div class="col-md-3">
            <label>Start Date</label>
            <input type="date" name="startDate" class="form-control" value="@selectedStartDate" />
        </div>
        <div class="col-md-3">
            <label>End Date</label>
            <input type="date" name="endDate" class="form-control" value="@selectedEndDate" />
        </div>
    </div>
    <button type="submit" class="btn btn-primary mt-2">Filter</button>
    <a asp-action="Index" class="btn btn-secondary mt-2">Clear Filters</a>
</form>

<!-- Results Table -->
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Contract ID</th>
            <th>Client Name</th>
            <th>Service Level</th>
            <th>Start Date</th>
            <th>End Date</th>
            <th>Status</th>
            <th>Agreement PDF</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
    @foreach (var contract in Model)
    {
        <tr>
            <td>@contract.ContractId</td>
            <td>@contract.Client?.ClientName</td>
            <td>@contract.ContractServiceLevel</td>
            <td>@contract.StartDate.ToShortDateString()</td>
            <td>@contract.EndDate.ToShortDateString()</td>
            <td>@contract.ContractStatus</td>
            <td>
                @if (!string.IsNullOrEmpty(contract.PdfFilePath))
                {
                    <a href="@Url.Content(contract.PdfFilePath)" target="_blank">View PDF</a>
                }
            </td>
            <td>
                <a asp-action="Details" asp-route-id="@contract.ContractId" class="btn btn-info btn-sm">Details</a>
                <a asp-action="Edit" asp-route-id="@contract.ContractId" class="btn btn-warning btn-sm">Edit</a>
                <a asp-action="Delete" asp-route-id="@contract.ContractId" class="btn btn-danger btn-sm">Delete</a>
            </td>
        </tr>
    }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success">Create New Contract</a>
