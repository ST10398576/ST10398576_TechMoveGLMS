@model ST10398576_TechMoveGLMS.Models.Client

@{
    ViewData["Title"] = "Delete Client";
}

<h2>Delete Client</h2>

<h3>Are you sure you want to delete this client?</h3>

<dl class="row">
    <dt class="col-sm-2">Name</dt>
    <dd class="col-sm-10">@Model.ClientName</dd>

    <dt class="col-sm-2">Contact Details</dt>
    <dd class="col-sm-10">@Model.ClientContactDetails</dd>

    <dt class="col-sm-2">Region</dt>
    <dd class="col-sm-10">@Model.ClientRegion</dd>
</dl>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="ClientId" />
    <button type="submit" class="btn btn-danger">Delete</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
