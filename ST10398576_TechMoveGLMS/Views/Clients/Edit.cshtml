@model ST10398576_TechMoveGLMS.Models.Client

@{
    ViewData["Title"] = "Edit Client";
}

<h2>Edit Client</h2>

<div asp-validation-summary="All" class="text-danger"></div>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="ClientId" />

    <div class="form-group">
        <label asp-for="ClientName" class="control-label"></label>
        <input asp-for="ClientName" class="form-control" />
        <span asp-validation-for="ClientName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ClientContactDetails" class="control-label"></label>
        <input asp-for="ClientContactDetails" class="form-control" />
        <span asp-validation-for="ClientContactDetails" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ClientRegion" class="control-label"></label>
        <input asp-for="ClientRegion" class="form-control" />
        <span asp-validation-for="ClientRegion" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</form>
