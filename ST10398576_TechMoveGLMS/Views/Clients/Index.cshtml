@model IEnumerable<ST10398576_TechMoveGLMS.Models.Client>
@{
    ViewData["Title"] = "Clients";
}

<h2>Clients</h2>

<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Name</th>
            <th>Contact Details</th>
            <th>Region</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var client in Model)
        {
            <tr>
                <td>@client.ClientName</td>
                <td>@client.ClientContactDetails</td>
                <td>@client.ClientRegion</td>
                <td>
                    <a asp-action="Details" asp-route-id="@client.ClientId" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@client.ClientId" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@client.ClientId" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>

<a asp-action="Create" class="btn btn-success">Create New Client</a>
